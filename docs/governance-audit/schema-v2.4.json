{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fatdinhero/verifiable-ai-stack/docs/governance-audit/schema-v2.4.json",
  "title": "verifiable-ai-stack Governance Audit Report v2.4",
  "type": "object",
  "required": [
    "report_schema",
    "report_version",
    "metadata",
    "source",
    "source_sha256",
    "parameters",
    "quality_gate",
    "summary",
    "validators",
    "claims",
    "integrity"
  ],
  "properties": {
    "report_schema": {
      "const": "verifiable-ai-stack/governance-audit/v2.4"
    },
    "report_version": {
      "const": "2.4.0"
    },
    "metadata": {
      "type": "object",
      "required": ["report_id", "tool", "tool_version", "generated_at", "git", "runtime"],
      "properties": {
        "report_id": {"type": "string", "minLength": 64, "maxLength": 64},
        "tool": {"const": "cognitum-governance-audit"},
        "tool_version": {"const": "2.4.0"},
        "generated_at": {"type": "string"},
        "git_commit": {"type": ["string", "null"]},
        "git": {"type": "object"},
        "runtime": {"type": "object"},
        "dependencies": {"type": "object"}
      },
      "additionalProperties": true
    },
    "source_sha256": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "quality_gate": {
      "type": "object",
      "required": ["name", "status", "passed", "thresholds", "observed", "merge_check"],
      "properties": {
        "name": {"const": "governance-audit"},
        "status": {"enum": ["passed", "failed"]},
        "passed": {"type": "boolean"},
        "thresholds": {"type": "object"},
        "observed": {"type": "object"},
        "failure_reasons": {
          "type": "array",
          "items": {"type": "string"}
        },
        "merge_check": {
          "type": "object",
          "required": ["workflow", "job", "required_status_check", "github_merge_queue_event"],
          "properties": {
            "github_merge_queue_event": {"const": "merge_group"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": ["claim_count", "validator_count", "mean_s_con", "psi", "accepted"],
      "properties": {
        "claim_count": {"type": "integer", "minimum": 1},
        "validator_count": {"type": "integer", "minimum": 1},
        "mean_s_con": {"type": "number", "minimum": 0, "maximum": 1},
        "psi": {"type": "number", "minimum": 0, "maximum": 1},
        "accepted": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string"},
          "version": {"type": ["string", "null"]},
          "duration_ms": {"type": ["number", "null"]}
        },
        "additionalProperties": true
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "original_claim_sha256", "kind", "statement", "s_con"],
        "properties": {
          "id": {"type": "string", "minLength": 64, "maxLength": 64},
          "original_claim_sha256": {"type": "string", "minLength": 64, "maxLength": 64},
          "kind": {"type": "string"},
          "statement": {"type": "string"},
          "s_con": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "additionalProperties": true
      }
    },
    "integrity": {
      "type": "object",
      "required": ["report_payload_sha256", "signature"],
      "properties": {
        "report_payload_sha256": {"type": "string", "minLength": 64, "maxLength": 64},
        "signature": {"type": "object"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
